# ─── Base de datos ─────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena tus valores reales
# NUNCA subas el archivo .env al repositorio

# Cadena de conexión de MongoDB Atlas
MONGO_CLUSTER_URL=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/?appName=AgroDirecto

# ─── Autenticación ──────────────────────────────────────────────────────────────
# Clave secreta para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_una_clave_segura_y_larga

# ─── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS (producción) ──────────────────────────────────────────────────────────
# URL del frontend en Vercel. Se puede poner varias separadas por coma.
# En dev no hace falta definirla (los puertos locales de Vite están permitidos por defecto).
# Ejemplo: ALLOWED_ORIGINS=https://agrodirecto.vercel.app
ALLOWED_ORIGINS=

# ─── Frontend (Vite) ────────────────────────────────────────────────────────────
# URL del backend en Render. Dejar vacío en dev (el proxy de Vite lo gestiona).
# Ejemplo: VITE_API_URL=https://agrodirecto-api.onrender.com
VITE_API_URL=
