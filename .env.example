# ─── Base de datos ─────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena tus valores reales
# NUNCA subas el archivo .env al repositorio

# Cadena de conexión de MongoDB Atlas
MONGO_CLUSTER_URL=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/?appName=AgroDirecto

# ─── Autenticación ──────────────────────────────────────────────────────────────
# Clave secreta para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_una_clave_segura_y_larga

# ─── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend (Vite) ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
